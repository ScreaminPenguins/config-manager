#!/usr/bin/env bash

WORK="$HOME/Repositories/work"
PERSONAL="$HOME/Repositories/personal"
OBSIDIAN="${HOME}/Documents/McWork"

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$({ find "$WORK" "$PERSONAL" "$DOTFILES" -mindepth 1 -maxdepth 6 \
        -name '.git' -type d -prune | sed 's|/.git$||'; echo "$OBSIDIAN"; } | fzf --border=double)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)

is_new=0
if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    is_new=1
    tmux new-session -d -s "$selected_name" -n "Nvim" -c "$selected"
    tmux new-window -t "$selected_name" -n "Shell" -c "$selected"

    tmux send-keys -t "$selected_name:0" nvim ENTER
fi

if [[ -n "${TMUX:-}" ]]; then
    if [[ $is_new -eq 1 ]]; then
        tmux switch-client -t "$selected_name:Nvim"
    else
        tmux switch-client -t "$selected_name"
    fi
else
    tmux attach-session -t "$selected_name:Nvim"
fi
